{
  "name": "tour-management-system",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build:analyze": "ANALYZE=true next build --webpack",
    "build:production": "NODE_ENV=production next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit",
    "type-check:pages": "node --max-old-space-size=8192 scripts/typecheck-pages.cjs",
    "clean": "rm -rf .next out dist",
    "clean:all": "rm -rf .next out dist node_modules package-lock.json && npm install",
    "generate-thumbnails": "node scripts/generate-thumbnails.js",
    "generate-thumbnails:tour": "node scripts/generate-thumbnails.js",
    "cleanup-tour-photos-buckets": "node scripts/cleanup-tour-photos-buckets.js",
    "backfill:pricing-revenue": "npx tsx --tsconfig tsconfig.json scripts/backfill-reservation-pricing-revenue.ts"
  },
